aws_region   = "ap-south-1"
project_name = "devops-capstone"

# Replace with your actual GitHub username/org and repo name
github_repo = "your-github-username/devops-capstone-project"

# Run: curl -s ifconfig.me   (then append /32)
my_ip_cidr = "203.0.113.5/32"

# Contents of your SSH public key file, e.g.: cat ~/.ssh/devops-capstone-key.pub
ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI... your-email@example.com"

instance_type       = "t3.medium"
budget_alert_email  = "shivchandan1203@gmail.com"